# Copy to `.env` and adjust paths (never commit `.env`).

# Absolute path to your Obsidian vault root (or use ~/...).
# Example macOS: /Users/you/Documents/Obsidian/MyVault
KB_VAULT_PATH=

# Optional: SQLite index file. Default: <KB_VAULT_PATH>/.kb-index.db
# KB_DB_PATH=

# Optional: override default top-level vault folder names (comma-free JSON object).
# Keys: raw, wiki, projects, people, decisions, agentMemory, sessions, indexes, templates, archive
# KB_VAULT_DIRS_JSON={"wiki":"content/wiki"}

# Or set individual folders, e.g.:
# KB_DIR_WIKI=01-wiki
# KB_DIR_INDEXES=07-indexes
